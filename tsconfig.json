{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./build",
		"target": "esnext",
		"module": "commonjs",
		"paths": {
			"@src/*": ["./src/*"],
			"@rest-apis/*": ["./src/rest-apis/*"],
			"@websockets/*": ["./src/websockets/*"],
			"@lib/*": ["./src/lib/*"]
		},
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noUnusedLocals": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"noImplicitAny": false,
		"types": ["./src/shared/types/fastify.d.ts", "./src/shared/types/env.d.ts"]
	},
	"ts-node": {
		"require": ["tsconfig-paths/register"]
	},
	"exclude": ["node_modules", "build"]
}
