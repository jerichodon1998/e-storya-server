{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./build",
		"target": "esnext",
		"module": "commonjs",
		"paths": {
			"@/*": ["./src/*"],
			"@rest-apis/*": ["./src/rest-apis/*"],
			"@websockets/*": ["./src/websockets/*"],
			"@lib/*": ["./src/lib/*"]
		},
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noUnusedLocals": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"noImplicitAny": false
	},
	"ts-node": {
		"require": ["tsconfig-paths/register"]
	},
	"include": ["./src/**/*"],
	"exclude": ["node_modules", "build"]
}
