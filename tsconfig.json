{
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"baseUrl": "./src",
		"rootDir": "./src",
		"outDir": "./build",
		"module": "nodenext",
		"target": "esnext",
		"paths": {
			"@/*": ["src/*"],
			"@lib/*": ["src/lib/*"]
		},
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noUnusedLocals": true,
		"strict": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"noImplicitAny": false
	}
}
